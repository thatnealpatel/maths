{{define "content"}}
<style>
.C2ST--Tooltip {
    position: fixed;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-family);
    font-size: 0.8125rem;
    line-height: 1.5;
    padding: 0.4rem 0.6rem;
    pointer-events: none;
    display: none;
    z-index: 10;
}
</style>

<h1>C2ST Power Surface</h1>
<p>
    The Classifier Two-Sample Test trains a bagged CART ensemble to distinguish
    samples from F&#x2081; vs F&#x2082;. This heatmap shows rejection rate (power)
    across correlation strength &#x03C1; and dimensionality p.
    F&#x2082; differs from F&#x2081; only in a correlation &#x03C1; between dimensions 0 and 1.
</p>

<div class="Controls--Tags">
    <span class="Tag">100 trees</span>
    <span class="Tag">depth 5</span>
    <span class="Tag">5-fold CV</span>
    <span class="Tag">30 reps/cell</span>
    <span class="Tag">n = 300</span>
</div>

<hr>

<div class="Section--Label">Rejection Rate Heatmap</div>

<div class="Vis">
    <canvas class="Vis--Canvas" id="c2st-canvas"
            hx-get="/robustness/c2st/data"
            hx-swap="none"
            hx-trigger="load"
            hx-on::after-request="handleC2ST(event)"></canvas>
</div>

<div class="C2ST--Tooltip" id="c2st-tooltip"></div>
{{end}}

{{define "scripts"}}
<script>
var c2stData = null;
var c2stLayout = null;

function handleC2ST(event) {
    if (!event.detail.successful) return;
    c2stData = JSON.parse(event.detail.xhr.responseText);
    drawC2ST();
}

function drawC2ST() {
    if (!c2stData) return;
    var canvas = document.getElementById('c2st-canvas');
    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var w = rect.width, h = rect.height;
    var pad = {t: 10, r: 15, b: 35, l: 40};
    var pw = w - pad.l - pad.r;
    var ph = h - pad.t - pad.b;

    var rhos = c2stData.rho_values;
    var ps = c2stData.p_values;
    var nCols = rhos.length;
    var nRows = ps.length;
    var cellW = pw / nCols;
    var cellH = ph / nRows;

    c2stLayout = {pad: pad, cellW: cellW, cellH: cellH, nCols: nCols, nRows: nRows};

    ctx.clearRect(0, 0, w, h);

    for (var i = 0; i < c2stData.cells.length; i++) {
        var cell = c2stData.cells[i];
        var col = rhos.indexOf(cell.rho);
        var row = ps.indexOf(cell.p);
        if (col < 0 || row < 0) continue;

        var t = cell.rejection_rate;
        var r = Math.round(245 + (192 - 245) * t);
        var g = Math.round(242 + (82 - 242) * t);
        var b = Math.round(235 + (42 - 235) * t);

        var x = pad.l + col * cellW;
        var y = pad.t + row * cellH;

        ctx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        ctx.fillRect(x, y, cellW, cellH);

        ctx.strokeStyle = '#D6D2C9';
        ctx.lineWidth = 1;
        ctx.strokeRect(x, y, cellW, cellH);

        ctx.fillStyle = t > 0.5 ? '#F5F2EB' : '#2C2B28';
        ctx.font = '13px IBM Plex Mono, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(cell.rejection_rate.toFixed(2), x + cellW / 2, y + cellH / 2);
    }

    ctx.fillStyle = '#A8A49C';
    ctx.font = '13px IBM Plex Mono, monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    for (var c = 0; c < nCols; c++) {
        ctx.fillText(rhos[c].toFixed(1), pad.l + (c + 0.5) * cellW, pad.t + ph + 6);
    }
    ctx.textBaseline = 'top';
    ctx.fillText('\u03C1', pad.l + pw / 2, pad.t + ph + 20);

    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    for (var r = 0; r < nRows; r++) {
        ctx.fillText(ps[r].toString(), pad.l - 8, pad.t + (r + 0.5) * cellH);
    }
    ctx.save();
    ctx.translate(12, pad.t + ph / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText('p', 0, 0);
    ctx.restore();
}

(function() {
    var canvas = document.getElementById('c2st-canvas');
    var tip = document.getElementById('c2st-tooltip');

    canvas.addEventListener('mousemove', function(e) {
        if (!c2stData || !c2stLayout) return;
        var rect = canvas.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var lay = c2stLayout;

        var col = Math.floor((x - lay.pad.l) / lay.cellW);
        var row = Math.floor((y - lay.pad.t) / lay.cellH);

        if (col >= 0 && col < lay.nCols && row >= 0 && row < lay.nRows) {
            var rho = c2stData.rho_values[col];
            var p = c2stData.p_values[row];
            var cell = null;
            for (var i = 0; i < c2stData.cells.length; i++) {
                if (c2stData.cells[i].rho === rho && c2stData.cells[i].p === p) {
                    cell = c2stData.cells[i];
                    break;
                }
            }
            if (cell) {
                tip.innerHTML =
                    '\u03C1 = ' + rho.toFixed(2) + ', p = ' + p + '<br>' +
                    'Rejection: ' + cell.rejection_rate.toFixed(2) + '<br>' +
                    'Accuracy: ' + cell.mean_acc.toFixed(3) + ' \u00B1 ' + cell.std_acc.toFixed(3);
                tip.style.display = 'block';
                tip.style.left = (e.clientX + 12) + 'px';
                tip.style.top = (e.clientY + 12) + 'px';
            }
        } else {
            tip.style.display = 'none';
        }
    });

    canvas.addEventListener('mouseleave', function() {
        tip.style.display = 'none';
    });
})();
</script>
{{end}}
